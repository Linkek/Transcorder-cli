{
  "name": "transcorder",
  "version": "1.2.1",
  "description": "Video transcoding daemon with NVIDIA NVENC support",
  "type": "module",
  "bin": {
    "transcorder": "./dist/cli.js"
  },
  "scripts": {
    "setup": "npm install && cd web && npm install && npm run build && cd .. && node -e \"const fs=require('fs');if(!fs.existsSync('config/profiles.json')){fs.copyFileSync('config/profiles.example.json','config/profiles.json');console.log('Created config/profiles.json from example')}else{console.log('config/profiles.json already exists')}\"",
    "start": "tsx src/cli.ts",
    "daemon": "tsx src/cli.ts daemon",
    "daemon:verbose": "tsx src/cli.ts daemon --verbose",
    "scan": "tsx src/cli.ts scan",
    "scan:verbose": "tsx src/cli.ts scan --verbose",
    "audit": "tsx src/cli.ts audit",
    "build": "tsc && cd web && npx vite build",
    "build:cli": "tsc",
    "build:web": "cd web && npm install && npm run build",
    "kill": "pkill -f 'tsx src/cli.ts' 2>/dev/null; fuser -k 9800/tcp 2>/dev/null; echo 'Done'",
    "test": "vitest",
    "test:run": "vitest run --exclude tests/aspect-ratio.integration.test.ts",
    "test:integration": "vitest run tests/aspect-ratio.integration.test.ts",
    "test:all": "vitest run",
    "test:coverage": "vitest run --coverage",
    "transcorder": "tsx src/cli.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "chokidar": "^4.0.3",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "figures": "^6.1.0",
    "fluent-ffmpeg": "^2.1.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cli-progress": "^3.11.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.13.5",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
}
